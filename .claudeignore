# ──────────────────────────────────────────────────────────────────────
# .claudeignore — avating-web
#
# AI(Claude) 가 작업 시 읽지 말아야 할 경로.
# 목적:
#   1) 컨텍스트 윈도우 절약 — 거대 생성물/락파일/캐시 차단
#   2) 보안 — .env 실값/키/자격증명 노출 차단
#   3) 노이즈 제거 — OS/에디터 잡파일, 로그, 테스트 리포트 제외
#
# 살려둘 경로(명시): src/, .claude/{plans,notes,skills,agents,api}/,
#   CLAUDE.md, package.json, tsconfig*, eslint.config.js, vite.config.*,
#   vitest.config.*, .env.example, index.html, README.md
#
# 보안 항목 변경은 사용자 승인 필수 (.gitignore 와 동일 정책).
# ──────────────────────────────────────────────────────────────────────

# ── 의존성 / 빌드 산출물
node_modules
bower_components
dist
dist-ssr
build
.vite
*.tsbuildinfo

# ── 락파일 (거대한 생성물 — 읽을 필요 없음)
pnpm-lock.yaml
package-lock.json
yarn.lock

# ── 환경 변수 실값 (.env.example 만 허용)
.env
.env.*
!.env.example

# ── 비밀 / 자격증명
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_ed25519
known_hosts
.ssh/
.aws/
.gcloud/
gcp-*.json
*-sa-*.json
service-account*.json
credentials.json
secrets.json
secret.json
.sentryclirc
.amplitude/

# ── 로그
*.log
logs
npm-debug.log*
pnpm-debug.log*
yarn-error.log

# ── 테스트 / 커버리지 / 리포트
coverage
playwright-report
test-results
blob-report
.nyc_output

# ── Storybook 빌드 산출물
storybook-static
.storybook-static

# ── 도구 캐시
.eslintcache
.turbo
.cache
.parcel-cache
.swc

# ── Terraform 산출물 (IaC 도입 시)
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/

# ── 에디터 / OS 잡파일
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/*.code-snippets
.idea
.zed
.history/
.history
.ionide
*.iml
*.vsix
*.swp
*.swo
*.suo
*.sublime-project
*.sublime-workspace
.DS_Store
.DS_*
Thumbs.db

# ── Claude 로컬 전용 (개인 환경)
.claude/settings.local.json
.claude/*.local.*

# ── Git 내부
.git/

# ── 워크트리 / 임시
/.worktrees
tmp/
.tmp/
*.local

# ── 백업/스냅샷
**/*.backup.*
**/*.back.*
